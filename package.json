{
  "name": "fin-agent-owl",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "checkall": "bun run lint:fix & bun run lint:format && bun run typecheck",
    "dev": "wxt",
    "icons": "bun run scripts/generate-icons.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:format": "oxfmt --write .",
    "postinstall": "wxt prepare",
    "typecheck": "wxt prepare && tsc --noEmit",
    "zip": "wxt zip"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "wxt": "^0.20.20"
  }
}
